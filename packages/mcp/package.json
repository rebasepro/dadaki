    "private": true,
    "type": "module",
    "bin": {
        "dadaki-mcp": "./src/index.ts"
    },
    "scripts": {
        "start": "node --experimental-strip-types src/index.ts",
        "smoke": "node --experimental-strip-types smoke.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.22.0",
        "puppeteer": "^25.3.0",
        "zod": "^3.25.0"
    }
}
