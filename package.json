{
    "name": "dadaki-vector-editor-workspace",
    "version": "1.0.0",
    "description": "Workspace root: @dadaki/editor (OSS library) + @dadaki/app (deployable demo).",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite packages/app --port 5199",
        "start": "vite packages/app --port 5199",
        "build": "vite build packages/app",
        "preview": "vite preview packages/app --port 5199",
        "dev:cloud": "test -d cloud || { echo 'cloud/ is a separate repo and is not part of the open-source editor — nothing to run here.'; exit 1; }; cd cloud && ./node_modules/.bin/rebase dev",
        "build:cloud": "test -d cloud || { echo 'cloud/ is a separate repo and is not part of the open-source editor — nothing to run here.'; exit 1; }; cd cloud && ./node_modules/.bin/rebase build",
        "test": "vitest run",
        "check": "tsc --noEmit",
        "lint": "biome check",
        "format": "biome format --write"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.1.0",
            "onFail": "download"
        }
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.3",
        "@types/node": "^26.1.0",
        "jsdom": "^29.1.1",
        "puppeteer": "^25.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.9"
    }
}
